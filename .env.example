# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL — use "postgres" host when running inside Docker, "localhost" when running locally
DATABASE_URL=postgresql://argos:argos@postgres:5432/argos

# Redis — use "redis" host inside Docker, "localhost" locally
REDIS_URL=redis://redis:6379

# JWT — must be at least 32 characters each
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-string-min
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-string

# SMTP (MailHog locally)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=Argos Clone <no-reply@argos.local>

# CORS allowed origin
CLIENT_URL=http://localhost:3000

# Local image upload destination (Phase 2 introduces Multer + sharp)
UPLOAD_DIR=./uploads
STATIC_PREFIX=/static

# ─── Razorpay (test mode) ──────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YourSecretFromDashboardHere

# DEV ONLY: when 'true', the server accepts a sentinel signature `dev_bypass`
# from POST /checkout/verify, skipping HMAC verification. Combined with the
# client flag VITE_PAYMENT_BYPASS, this bypasses the Razorpay popup entirely
# for local testing. Joi validation refuses to boot the server if this is
# 'true' while NODE_ENV is not 'development'. Default: 'false'.
PAYMENT_BYPASS_ENABLED=false

# ─── Client (Vite prefix required) ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
