# Normalise line endings — always LF in the repo, CRLF only on checkout if the OS prefers it
* text=auto eol=lf

# Force LF on shell scripts (Husky hooks run via Git Bash on Windows)
*.sh text eol=lf
.husky/* text eol=lf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
