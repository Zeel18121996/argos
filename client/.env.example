VITE_API_BASE_URL=http://localhost:3001/api
VITE_APP_TITLE=Argos

# Razorpay public key (same value as RAZORPAY_KEY_ID on the server). NEVER put the secret here.
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX

# DEV ONLY: when 'true', the checkout skips Razorpay's popup and calls
# /checkout/verify directly with a sentinel signature. The server-side flag
# PAYMENT_BYPASS_ENABLED must also be 'true' for the verify call to succeed.
# Default: 'false' (real Razorpay popup flow).
VITE_PAYMENT_BYPASS=false
